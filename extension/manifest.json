{
    "manifest_version": 3,
    "name": "JDScope",
    "version": "1.0",
    "description": "Analyze Job Descriptions",
    "permissions": [
        "activeTab"
    ],
    "host_permissions": [
        "https://www.linkedin.com/*"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "content_scripts": [
        {
            "matches": [
                "https://www.linkedin.com/jobs/*"
            ],
            "js": [
                "content.js"
            ]
        }
    ]
}